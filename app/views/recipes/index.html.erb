<% content_for :title, 'Recipes' %>
<h1>Recipes</h1>

<%= form_with url: recipes_path, method: :get, local: true do %>
  <p>
    <%= label_tag :q, 'Search' %>
    <%= search_field_tag :q, params[:q] %>
    <%= submit_tag 'Search' %>
  </p>
<% end %>

<ul>
  <% @recipes.each do |recipe| %>
    <li>
      <p><%= link_to recipe.title, recipe_path(recipe.id) %></p>
      <p><strong>Tags:</strong> <%= recipe.tags_label %></p>
      <p><strong>Description:</strong> <%= recipe.preview %></p>
    </li>
  <% end %>
</ul>
