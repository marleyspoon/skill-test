# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
#
# Temporary files, logs, and local secrets.
/.bundle/
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
.byebug_history
/config/master.key
/config/credentials/*.key

# Ignore storage (if added later).
/storage/*
!/storage/.keep

# Ignore assets precompile cache.
/public/assets
/node_modules
/yarn-error.log

# Ignore IDE and OS files.
.DS_Store
*.swp
.idea/
.env
.env.*
